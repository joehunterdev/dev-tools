# ============================================================
# XAMPP Tools Configuration
# ============================================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ------------------------------------------------------------
# Configurables
# ------------------------------------------------------------
ENVIRONMENT_TYPE=optimum
BACKUP_PATH_TYPE=

# ------------------------------------------------------------
# XAMPP Paths
# ------------------------------------------------------------
XAMPP_ROOT_DIR=C:\xampp
XAMPP_DOCUMENT_ROOT=C:\www
VSCODE_THEME_EXTENSION=

# ------------------------------------------------------------
# Server Settings
# ------------------------------------------------------------
XAMPP_SERVER_NAME=localhost
XAMPP_SERVER_IP=127.0.0.1
XAMPP_SERVER_PORT=8080
XAMPP_SSL_PORT=443

# ------------------------------------------------------------
# MySQL
# ------------------------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_ROOT_PASSWORD=

# ------------------------------------------------------------
# phpMyAdmin
# ------------------------------------------------------------
PMA_AUTH_TYPE=cookie
PMA_ALLOW_NO_PASSWORD=false
PMA_BLOWFISH_SECRET=
PMA_USER=pma
PMA_PASSWORD=
PMA_MEMORY_LIMIT=512M
PMA_EXEC_TIME_LIMIT=600

# ------------------------------------------------------------
# PHP Settings
# ------------------------------------------------------------
PHP_VERSION=8.4
PHP_POST_MAX_SIZE=600M
PHP_UPLOAD_MAX_FILESIZE=600M

# ------------------------------------------------------------
# VHosts
# ------------------------------------------------------------
VHOSTS_EXTENSION=.localhost
IS_IPV6=false
