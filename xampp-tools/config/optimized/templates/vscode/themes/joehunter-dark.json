  // ── Token Colors (Syntax) ──────────────────────────────────────────────────
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#03f8bd", "fontStyle": "italic" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "keyword.control", "keyword.operator.new", "keyword.other.using"],
      "settings": { "foreground": "#569cd6" }
    },
    {
      "name": "Storage types",
      "scope": ["storage.type", "storage.modifier"],
      "settings": { "foreground": "#569cd6", "fontStyle": "italic" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#dcdcdc" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#d69d85" }
    },
    {
      "name": "String escapes",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#9a5334" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#b8d7a3" }
    },
    {
      "name": "Constants",
      "scope": ["constant.language", "constant.other"],
      "settings": { "foreground": "#569cd6" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#dcdcdc" }
    },
    {
      "name": "Variables — special (this, self)",
      "scope": ["variable.language"],
      "settings": { "foreground": "#569cd6", "fontStyle": "italic" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#9cdcfe" }
    },
    {
      "name": "Properties",
      "scope": ["variable.other.property", "meta.property-name", "support.type.property-name"],
      "settings": { "foreground": "#9cdcfe" }
    },
    {
      "name": "Functions",
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": { "foreground": "#dcdcaa" }
    },
    {
      "name": "Classes / types",
      "scope": ["entity.name.class", "entity.name.type", "support.class"],
      "settings": { "foreground": "#4ec9b0" }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
      "settings": { "foreground": "#b8d7a3" }
    },
    {
      "name": "Namespaces / modules",
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": { "foreground": "#dcdcdc" }
    },
    {
      "name": "Enum members",
      "scope": ["variable.other.enummember", "variable.other.constant"],
      "settings": { "foreground": "#b8d7a3" }
    },
    {
      "name": "Built-in types",
      "scope": ["support.type"],
      "settings": { "foreground": "#4ec9b0" }
    },
    {
      "name": "Decorators / annotations",
      "scope": ["meta.decorator", "entity.name.function.decorator"],
      "settings": { "foreground": "#bd63c5", "fontStyle": "italic" }
    },
    // ── HTML / JSX ────────────────────────────────────────────────────────────
    {
      "name": "Tags",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": { "foreground": "#569cd6" }
    },
    {
      "name": "Attribute names",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#9cdcfe" }
    },
    {
      "name": "Attribute values",
      "scope": ["string.quoted.double.html", "string.quoted.single.html"],
      "settings": { "foreground": "#d69d85" }
    },
    // ── CSS / SCSS ────────────────────────────────────────────────────────────
    {
      "name": "CSS selectors",
      "scope": ["meta.selector", "entity.other.attribute-name.class.css"],
      "settings": { "foreground": "#d7ba7d" }
    },
    {
      "name": "CSS id selectors",
      "scope": ["entity.other.attribute-name.id"],
      "settings": { "foreground": "#8869b4" }
    },
    {
      "name": "CSS property names",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#9cdcfe" }
    },
    {
      "name": "CSS property values",
      "scope": ["support.constant.property-value", "meta.property-value"],
      "settings": { "foreground": "#dcdcdc" }
    },
    {
      "name": "CSS units / numbers",
      "scope": ["constant.numeric.css", "keyword.other.unit"],
      "settings": { "foreground": "#b8d7a3" }
    },
    {
      "name": "CSS colours",
      "scope": ["constant.other.color"],
      "settings": { "foreground": "#03f8bd" }
    },
    {
      "name": "CSS pseudo-selectors",
      "scope": ["entity.other.attribute-name.pseudo-class", "entity.other.attribute-name.pseudo-element"],
      "settings": { "foreground": "#d7ba7d", "fontStyle": "italic" }
    },
    {
      "name": "CSS at-rules / SCSS keywords",
      "scope": ["keyword.control.at-rule", "keyword.at-rule"],
      "settings": { "foreground": "#569cd6" }
    },
    {
      "name": "SCSS variables",
      "scope": ["variable.scss", "variable.other.scss"],
      "settings": { "foreground": "#9cdcfe" }
    },
    // ── JSON ──────────────────────────────────────────────────────────────────
    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#9cdcfe" }
    },
    // ── Markdown ──────────────────────────────────────────────────────────────
    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#8869b4", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#dcdcdc", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#dcdcdc", "fontStyle": "italic" }
    },
    {
      "name": "Markdown inline code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#03f8bd" }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#569cd6" }
    },
    {
      "name": "Markdown blockquote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#9b9b9b", "fontStyle": "italic" }
    },
    // ── Misc ──────────────────────────────────────────────────────────────────
    {
      "name": "Invalid / deprecated",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": { "foreground": "#f44747", "fontStyle": "strikethrough" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#dcdcdc" }
    }
  ],

  // ── Semantic Token Colors ──────────────────────────────────────────────────
  "semanticTokenColors": {
    "variable":                  "#dcdcdc",
    "variable.readonly":         "#9cdcfe",
    "variable.declaration":      "#dcdcdc",
    "parameter":                 "#9cdcfe",
    "property":                  "#9cdcfe",
    "property.readonly":         "#9cdcfe",
    "function":                  "#dcdcaa",
    "function.declaration":      { "foreground": "#dcdcaa", "bold": true },
    "method":                    "#dcdcaa",
    "class":                     "#4ec9b0",
    "interface":                 "#b8d7a3",
    "enum":                      "#4ec9b0",
    "enumMember":                "#b8d7a3",
    "struct":                    "#4ec9b0",
    "typeParameter":             "#b8d7a3",
    "namespace":                 "#dcdcdc",
    "decorator":                 { "foreground": "#bd63c5", "italic": true },
    "macro":                     "#569cd6",
    "comment":                   { "foreground": "#03f8bd", "italic": true },
    "string":                    "#d69d85",
    "number":                    "#b8d7a3",
    "keyword":                   "#569cd6",
    "operator":                  "#dcdcdc",
    "type":                      "#4ec9b0",
    "variable.readonly:javascript":  "#9cdcfe",
    "variable.readonly:typescript":  "#9cdcfe",
    "property.readonly:javascript":  "#9cdcfe",
    "property.readonly:typescript":  "#9cdcfe"
  }
}
